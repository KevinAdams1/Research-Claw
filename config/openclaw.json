{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "controlUi": {
      "root": "./dashboard/dist"
    }
  },
  "ui": {
    "assistant": {
      "name": "Research-Claw"
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "./node_modules/@wentorai/research-plugins/skills",
        "./skills"
      ]
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "research-claw-core": {
        "enabled": true,
        "config": {
          "dbPath": ".research-claw/library.db",
          "autoTrackGit": true,
          "defaultCitationStyle": "apa",
          "heartbeatDeadlineWarningHours": 48
        }
      },
      "wentor-connect": {
        "enabled": false
      }
    }
  },
  "tools": {
    "profile": "full",
    "alsoAllow": [
      "library_add_paper",
      "library_search",
      "library_update_paper",
      "library_get_paper",
      "library_export_bibtex",
      "library_reading_stats",
      "task_create",
      "task_list",
      "task_complete",
      "task_update",
      "task_link",
      "task_note",
      "workspace_save",
      "workspace_read",
      "workspace_list",
      "workspace_diff",
      "workspace_history",
      "workspace_restore"
    ]
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "enabled": true,
        "intervalMinutes": 30
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "env": {
    "vars": {}
  }
}
